---
import { Icon } from "astro-icon/components";
interface Props {
  title: string;
  description: string;
  type?: "text" | "link";
}
const { title, description, type = "text" }: Props = Astro.props;
---

{
  type === "link" ? (
    <a
      href={description}
      class="group flex w-fit flex-row items-center gap-2 font-semibold text-zinc-500 uppercase transition duration-200 ease-in-out hover:scale-110 hover:text-blue-400/80 active:scale-90 active:duration-100 dark:text-zinc-400 dark:hover:text-blue-400/60"
      target="_blank"
    >
      <Icon
        name={title.includes("Repo") ? "mdi:github" : "mdi:web"}
        class="h-6 w-6 text-zinc-500 transition-colors duration-200 group-hover:text-blue-400/80 dark:text-zinc-400 dark:group-hover:text-blue-400/60"
      />
      <span>{title}</span>
    </a>
  ) : (
    <div class="flex flex-col justify-start">
      <p class="text-sm text-zinc-500 uppercase">{title}</p>

      <p class="text-lg font-semibold uppercase">{description}</p>
    </div>
  )
}
